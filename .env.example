# Elasticsearch connection
ES_HOST=https://localhost:9200
ES_API_KEY=
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_CERTS=false
ES_ALERT_INDEX=.alerts-security.alerts-default

# Anthropic / Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Safety: keep DRY_RUN=true until you trust the pipeline and wire real integrations
DRY_RUN=true

# Polling
POLL_INTERVAL_SECONDS=60
